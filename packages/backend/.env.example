# All variables are optional — the server starts with these defaults.

PORT=3000

# Probability [0–1] that POST /analytics returns 503 SERVICE_UNAVAILABLE.
ANALYTICS_FAILURE_RATE=0

# Probability [0–1] that POST /orders returns 503 SERVICE_UNAVAILABLE
# (after stock and min-amount checks pass).
ORDER_FAILURE_RATE=0

# Artificial latency in milliseconds added to every response.
LATENCY_MS=0

# Integer seed for the random-number generator. When set, failure simulation
# and catalog generation are fully deterministic (useful for manual testing).
# SEED=42
