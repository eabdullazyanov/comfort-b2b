# dependencies
node_modules/

# yarn (berry) - keep releases, ignore the rest
.yarn/*
!.yarn/releases
!.yarn/patches
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# build output
dist/
build/
*.tsbuildinfo

# test / coverage
coverage/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env
.env.*
!.env.example

# os / editor
.DS_Store
*.pem

# react native (mobile) - native build artifacts
packages/mobile/ios/Pods/
packages/mobile/ios/build/
packages/mobile/ios/*.xcworkspace
packages/mobile/ios/.xcode.env.local
packages/mobile/android/.gradle/
packages/mobile/android/build/
packages/mobile/android/app/build/
packages/mobile/android/local.properties
# C++/CMake/NDK build intermediates — generated under android/app/.cxx (and
# android/.cxx); match anywhere under the android dir, not just the root.
packages/mobile/android/**/.cxx/
packages/mobile/android/.kotlin/
*.keystore
!debug.keystore
*.jsbundle
.metro-health-check*
vendor/bundle/
