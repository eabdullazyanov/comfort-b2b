# Copy to `packages/mobile/.env` and set the backend base URL for your build.
# Read by react-native-config and validated (as a URL) at app startup - there is
# no default, so this MUST be set.
#
# Android emulator reaches the host's localhost via 10.0.2.2:
# API_BASE_URL=http://10.0.2.2:3000
#
# iOS simulator reaches it via localhost:
# API_BASE_URL=http://localhost:3000

API_BASE_URL=http://localhost:3000
